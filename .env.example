# ─── Required ────────────────────────────────────────────────────────────────

# Base chain wallet address for receiving USDC payments (x402 protocol)
WALLET_ADDRESS=0xYourBaseChainAddress

# Admin API key – grants unlimited access, bypasses payment checks
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=your-secret-admin-key-here

# ─── Optional ────────────────────────────────────────────────────────────────

# Solana RPC endpoint (default: public mainnet)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Free tier limit per caller (default: 100)
FREE_TIER_LIMIT=100

# Price per request in USDC (default: 0.005)
PRICE_PER_REQUEST=0.005

# Public base URL (used for CSV download links in batch responses)
BASE_URL=https://tunapay-tx-classifier.fly.dev

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
